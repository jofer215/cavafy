# Google OAuth credentials — get from Google Cloud Console → APIs & Services → Credentials
# Scopes needed: openid email profile https://www.googleapis.com/auth/drive.file
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-secret

# NextAuth secret — generate with: openssl rand -base64 32
AUTH_SECRET=your-random-secret

# App URL — use localhost for dev, your Vercel URL for production
NEXTAUTH_URL=http://localhost:3000
